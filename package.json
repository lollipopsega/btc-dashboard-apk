{
  "name": "btc-onchain-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Dashboard local de Bitcoin con zonas de entrada, ciclo e indicadores.",
  "scripts": {
    "start": "node server.js",
    "mobile:add": "npx cap add android",
    "mobile:sync": "npx cap sync android",
    "mobile:open": "npx cap open android",
    "mobile:apk": "cd android && gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
